<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#a855f7;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ec4899;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="#0a0e1a"/>
  <circle cx="600" cy="315" r="200" fill="url(#grad1)" opacity="0.3"/>
  <text x="600" y="280" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="#f8fafc" text-anchor="middle">GameHub</text>
  <text x="600" y="330" font-family="Arial, sans-serif" font-size="24" fill="#94a3b8" text-anchor="middle">AI-Assisted Game Collection</text>
  <text x="600" y="370" font-family="Arial, sans-serif" font-size="18" fill="#6366f1" text-anchor="middle">Snake • Pong • Tic Tac Toe • Memory • Breakout • Flappy</text>
  <text x="600" y="550" font-family="Arial, sans-serif" font-size="16" fill="#4b5563" text-anchor="middle">Built with Claude Code &amp; Qwen</text>
</svg>
